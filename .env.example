# ---- Brain (OpenRouter) -------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any tool-capable model on OpenRouter. Good fast defaults:
#   anthropic/claude-haiku-4.5   openai/gpt-4o-mini   google/gemini-2.0-flash
# Low on credits? Try a free tool-capable model (may be rate-limited), e.g.:
#   meta-llama/llama-3.3-70b-instruct:free   or   z-ai/glm-4.5-air:free
FRIDAY_LLM_MODEL=anthropic/claude-haiku-4.5
FRIDAY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cap reply length (spoken replies are short; also bounds cost/credits per turn).
FRIDAY_LLM_MAX_TOKENS=800

# Optional: shown on your OpenRouter dashboard / rankings
FRIDAY_APP_URL=https://github.com/forloopcodes/friday
FRIDAY_APP_TITLE=FRIDAY

# ---- Behaviour ----------------------------------------------------------
FRIDAY_LOG_LEVEL=INFO
FRIDAY_WAKE_WORD=hey friday
FRIDAY_ASSISTANT_NAME=FRIDAY

# ---- Voice out (Phase 1) ------------------------------------------------
# sapi  = offline, zero-setup Windows voice (default, robotic — a placeholder)
# edge  = natural neural voice via Microsoft (needs internet; base voice for Miku)
# piper = offline high-quality-per-CPU (needs a downloaded .onnx model)
FRIDAY_TTS_ENGINE=sapi
# Engine-specific: SAPI voice-name substring, edge voice id (e.g.
# en-US-AriaNeural / ja-JP-NanamiNeural), or path to a Piper .onnx model.
FRIDAY_TTS_VOICE=
FRIDAY_TTS_SPEED=1.0
# sounddevice output device name/index; empty = system default.
FRIDAY_OUTPUT_DEVICE=

# ---- Miku voice (Phase 2) -----------------------------------------------
# Turn on with FRIDAY_TTS_ENGINE=miku (above). Runs on HF ZeroGPU, so a token
# is REQUIRED — create a free "read" token at hf.co/settings/tokens:
FRIDAY_HF_TOKEN=
HF_HUB_ENABLE_HF_TRANSFER=0

# Backend: "mikutts" = text -> Miku directly (default, no reference clip);
#          "gptsovits" = clone Miku from your own reference clip.
FRIDAY_MIKU_BACKEND=mikutts

# -- mikutts backend --
FRIDAY_MIKU_SPACE_ID=John6666/mikuTTS
# Built-in Miku model. Options include: "HATSUNE MIKU", "MikuAI",
# "Hatsune Miku V2 - VOCALOID (RVC) 250 Epoch", "kiramikuenglish", ...
FRIDAY_MIKU_MODEL=HATSUNE MIKU
# Base neural voice fed into RVC (English female works well for English replies):
FRIDAY_MIKU_BASE_VOICE=en-US-AriaNeural-Female
# Pitch shift toward Miku's register (raise if she sounds too low):
FRIDAY_MIKU_F0_UP_KEY=6
FRIDAY_MIKU_INDEX_RATE=0.75

# -- gptsovits backend (only if FRIDAY_MIKU_BACKEND=gptsovits) --
# FRIDAY_MIKU_SPACE_ID=lj1995/GPT-SoVITS-ProPlus
FRIDAY_MIKU_REF_AUDIO=
FRIDAY_MIKU_REF_TEXT=
FRIDAY_MIKU_REF_LANG=ja
FRIDAY_MIKU_TEXT_LANG=en
FRIDAY_MIKU_CUT=punct

FRIDAY_BASE_VOICE_LANG=ja
